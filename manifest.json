{
  "manifest_version": 3,
  "name": "SiteLauncher",
  "version": "1.0",
  "description": "高速サイトアクセス - ブックマークからキーで即座にサイトを開く",
  "permissions": [
    "bookmarks",
    "tabs"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "128": "icons/icon128.png"
  }
}
